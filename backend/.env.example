# backend/.env.example — TEMPLATE (committed, no real secrets).
# Copy to backend/.env and fill real values there. backend/.env is gitignored.

# Postgres connection string (note "+psycopg" = use the psycopg v3 driver):
#   postgresql+psycopg://<user>:<password>@<host>:<port>/<database>
# Local Homebrew Postgres uses your Mac username and no password.
DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/scholariq

# Secret used to sign JWT auth tokens (step 5). Use a long random string.
JWT_SECRET=change-me-to-a-long-random-string

# AI (deferred — not used in the first shippable version)
# ANTHROPIC_API_KEY=your-key-here
