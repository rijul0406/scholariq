# .env.example — a TEMPLATE showing which env vars the app needs.
# This file is COMMITTED (no real secrets). Copy it to `.env` and fill in
# real values there. `.env` is gitignored, so real secrets never leave your machine.

# Backend
DATABASE_URL=postgresql://user:password@localhost:5432/scholariq
JWT_SECRET=change-me-to-a-long-random-string

# AI (deferred — not used in the first shippable version)
# ANTHROPIC_API_KEY=your-key-here
